# Keep the deploy bundle small / clean.
venv/
.venv/
__pycache__/
**/__pycache__/
*.pyc
.env
.env.*
!.env.sample
uploads/
sources/
*.md
poetry.lock
# Poetry-format pyproject confuses Vercel's uv builder ("No `project` table").
# Excluding it makes Vercel install from requirements.txt instead.
pyproject.toml

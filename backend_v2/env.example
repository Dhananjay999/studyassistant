# API Keys
GROQ_API_KEY=your_groq_api_key_here
X-API-KEY=your_serper_api_key_here

# Model Configuration
GROQ_MODEL=llama3-8b-8192

# Application Settings
DEBUG=False
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:8080

# Database Settings
# CHROMA_DB_PATH will be auto-configured

# PostgreSQL Database Settings (Supabase)
DB_HOST=localhost
DB_NAME=aeva
DB_USER=aeva
DB_PASSWORD=
DB_PORT=5432

# ChromaDB Configuration
CHROMA_DB_API_KEY=
CHROMA_DB_TENANT=
CHROMA_DB_DATABASE=
CHROMA_DB_HOST=api.trychroma.com
CHROMA_DB_PATH=./chroma_db

# JWT Settings
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30 

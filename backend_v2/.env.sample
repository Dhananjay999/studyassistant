# Supabase
SUPABASE_URL=https://tadooavkfngedliceqjy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_publishable_GtqXy66W0rC9UibcXmGWIA_V9ix4Awz
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_STORAGE_BUCKET=study_media

# Gemini (Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key
# Default model for all capabilities (used when a specific model is not set).
LLM_MODEL=gemini-2.5-flash
# Optional per-capability models (each falls back to LLM_MODEL).
LLM_ORCHESTRATOR_MODEL=gemini-2.5-flash
LLM_WEB_SEARCH_MODEL=gemini-2.5-flash
LLM_MEDIA_MODEL=gemini-2.5-flash
LLM_QUIZ_MODEL=gemini-2.5-flash
LLM_FLASHCARD_MODEL=gemini-2.5-flash
# LLM provider per capability. Default is "gemini" (the only provider wired in
# today). Each falls back to LLM_PROVIDER when unset. To add a vendor: implement
# LLMProvider, register it in aeva/llm/providers/factory.py, set its API key
# here (e.g. OPENAI_API_KEY), then point a capability at it, e.g.
#   LLM_QUIZ_PROVIDER=openai
#   LLM_QUIZ_MODEL=gpt-4o
LLM_PROVIDER=gemini
LLM_ORCHESTRATOR_PROVIDER=gemini
LLM_WEB_SEARCH_PROVIDER=gemini
LLM_MEDIA_PROVIDER=gemini
LLM_QUIZ_PROVIDER=gemini
LLM_FLASHCARD_MODEL
# Max questions per generated quiz
QUIZ_MAX_QUESTIONS=10

# App
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
MAX_UPLOAD_MB=10

# OAuth (backend-driven Google login)
# Where the backend redirects the browser after a successful login.
FRONTEND_URL=http://localhost:5173
# Set to true in production (HTTPS) so the PKCE cookie is Secure.
COOKIE_SECURE=false

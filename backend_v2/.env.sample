# Supabase
SUPABASE_URL=https://tadooavkfngedliceqjy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_publishable_GtqXy66W0rC9UibcXmGWIA_V9ix4Awz
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_STORAGE_BUCKET=study_media

# Gemini (Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key
# Default model for all capabilities (used when a specific model is not set).
LLM_MODEL=gemini-2.5-flash
# Optional per-capability models (each falls back to LLM_MODEL).
LLM_ORCHESTRATOR_MODEL=gemini-2.5-flash
LLM_WEB_SEARCH_MODEL=gemini-2.5-flash
LLM_MEDIA_MODEL=gemini-2.5-flash
LLM_QUIZ_MODEL=gemini-2.5-flash
LLM_FLASHCARD_MODEL=gemini-2.5-flash
# Embedding model for the media RAG retrieval layer (its own model family).
LLM_EMBEDDING_MODEL=gemini-embedding-001
# LLM provider per capability. Providers wired in today: "gemini" and "groq".
# Each falls back to LLM_PROVIDER when unset. Point a capability at another
# provider by setting its *_PROVIDER (and optionally *_MODEL), e.g.
#   LLM_QUIZ_PROVIDER=groq
#   LLM_QUIZ_MODEL=openai/gpt-oss-20b
LLM_PROVIDER=gemini
LLM_ORCHESTRATOR_PROVIDER=gemini
LLM_WEB_SEARCH_PROVIDER=gemini
LLM_MEDIA_PROVIDER=gemini
LLM_QUIZ_PROVIDER=gemini
LLM_FLASHCARD_PROVIDER=gemini
LLM_EMBEDDING_PROVIDER=gemini

# Media RAG pipeline (LlamaParse + pgvector). LLAMA_CLOUD_API_KEY is optional:
# leave it blank to disable document parsing — the media tool then falls back to
# sending files directly to the LLM (the pre-RAG behavior), so the app still
# boots. Get a key at https://cloud.llamaindex.ai. LLAMAPARSE_MODE is the parse
# tier: cost_effective | agentic | agentic_plus (agentic tiers OCR images and
# handwriting). RAG_EMBEDDING_DIM MUST match the vector(N) column in migration
# 007 and the embedding output dimensionality.
LLAMA_CLOUD_API_KEY=
LLAMAPARSE_MODE=agentic
RAG_EMBEDDING_DIM=768
RAG_TOP_K=8
RAG_CHUNK_TOKENS=512
RAG_CHUNK_OVERLAP=64
# Answer not-yet-indexed docs from raw attachments instead of refusing. Set to
# false once all uploads are indexed to enforce retrieval-only answers.
RAG_ATTACHMENT_FALLBACK=true

# Groq (OpenAI-compatible API). Optional. To run a capability on Groq, set
# GROQ_API_KEY, point that capability's *_PROVIDER at "groq", and set its
# *_MODEL to a Groq model, e.g.:
#   LLM_QUIZ_PROVIDER=groq
#   LLM_QUIZ_MODEL=openai/gpt-oss-20b
# To use Groq everywhere, set LLM_PROVIDER=groq and LLM_MODEL=openai/gpt-oss-20b.
# Note: Groq has no web-search grounding, so web_search answers via Groq are
# ungrounded (no sources). Leave GROQ_API_KEY blank to keep Groq disabled.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Cap on completion tokens per Groq call. Reasoning models (e.g.
# openai/gpt-oss-20b) otherwise truncate long JSON mid-document, which Groq
# reports as "json_validate_failed". This cap is reserved against the account's
# tokens-per-minute (TPM) limit (prompt + cap must stay under TPM), so keep it
# modest on the free tier and raise it on higher tiers if responses get cut off.
GROQ_MAX_TOKENS=4096
# Reasoning effort for reasoning-capable Groq models: low | medium | high.
# Lower effort spends less of the token budget on reasoning, leaving room for
# the answer (this is what keeps structured output from being truncated). Set
# blank for non-reasoning Groq models (e.g. llama), which reject the parameter.
GROQ_REASONING_EFFORT=low

# Max questions per generated quiz
QUIZ_MAX_QUESTIONS=10

# App
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
MAX_UPLOAD_MB=10

# OAuth (backend-driven Google login)
# Where the backend redirects the browser after a successful login.
FRONTEND_URL=http://localhost:5173
# Set to true in production (HTTPS) so the PKCE cookie is Secure.
COOKIE_SECURE=false

# Super Admin panel (optional). Leave any of these blank to keep the panel
# disabled — its auth fails closed when unconfigured. Never commit real
# values. ADMIN_JWT_SECRET signs the admin session token (use a long random
# string, e.g. python -c "import secrets; print(secrets.token_urlsafe(48))").
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=
